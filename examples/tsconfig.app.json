{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "checkJs": true,
        "noImplicitAny": true,
        "strictNullChecks": true
    },
    "include": [
        "src/app/**/*.mjs",
        "src/app/**/*.js",
        "src/app/**/*.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "assets/wasm"
    ]
}
